{
  "name": "loreguard-mcp",
  "version": "0.1.0",
  "description": "Reviewed project memory for AI coding agents. SQLite-backed MCP server + CLI: agents can suggest reusable project knowledge; humans decide what becomes trusted lore.",
  "keywords": [
    "mcp",
    "model-context-protocol",
    "loreguard",
    "claude",
    "claude-code",
    "cursor",
    "ai-agents",
    "coding-agents",
    "agent-memory",
    "local-memory",
    "sqlite",
    "developer-tools"
  ],
  "license": "MIT",
  "author": "tmj <tommj_723@yahoo.co.uk>",
  "homepage": "https://github.com/tmj-90/loreguard-mcp#readme",
  "bugs": {
    "url": "https://github.com/tmj-90/loreguard-mcp/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tmj-90/loreguard-mcp.git"
  },
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "loreguard": "dist/bin/loreguard.js",
    "loreguard-mcp": "dist/bin/loreguard-mcp.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "docs",
    "skills"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "rimraf dist && tsc -p tsconfig.json && chmod +x dist/bin/loreguard.js dist/bin/loreguard-mcp.js",
    "dev:cli": "tsx src/bin/loreguard.ts",
    "dev:mcp": "tsx src/bin/loreguard-mcp.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepack": "npm run build"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "better-sqlite3": "^12.10.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.11",
    "@types/node": "^22.10.0",
    "rimraf": "^6.1.3",
    "tsx": "^4.22.3",
    "typescript": "^6.0.3",
    "vitest": "^2.1.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild"
    ]
  }
}
