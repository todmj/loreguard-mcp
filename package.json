{
  "name": "lore-mcp",
  "version": "0.1.0",
  "description": "Just-in-time local memory for AI coding agents. SQLite-backed MCP server and CLI for trusted, searchable, repo-scoped context.",
  "keywords": [
    "mcp",
    "model-context-protocol",
    "claude",
    "claude-code",
    "cursor",
    "ai-agents",
    "coding-agents",
    "agent-memory",
    "local-memory",
    "sqlite",
    "developer-tools"
  ],
  "license": "MIT",
  "author": "tmj <tommj_723@yahoo.co.uk>",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "lore": "dist/bin/lore.js",
    "lore-mcp": "dist/bin/lore-mcp.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "docs"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev:cli": "tsx src/bin/lore.ts",
    "dev:mcp": "tsx src/bin/lore-mcp.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepack": "pnpm run build"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "better-sqlite3": "^11.5.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.11",
    "@types/node": "^22.10.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
